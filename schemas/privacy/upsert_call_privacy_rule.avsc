{
  "name": "UpsertCallPrivacyRuleEvent",
  "type": "record",
  "namespace": "me.tinkle.events.privacy.v1",
  "doc": "Published by privacy-service when a call privacy rule override is created or updated. Event type discriminator: 'upsert_call_privacy_rule'. Topic: outbox.privacy.call. Aggregate: call.",
  "fields": [
    {
      "name": "user_id",
      "type": "long",
      "doc": "Snowflake ID of the rule owner."
    },
    {
      "name": "target_user_id",
      "type": "long",
      "doc": "Snowflake ID of the rule target."
    },
    {
      "name": "action",
      "type": "me.tinkle.events.privacy.v1.PrivacyRuleAction",
      "doc": "Allow or deny action for this target."
    }
  ]
}
